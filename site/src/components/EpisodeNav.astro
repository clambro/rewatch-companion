---
const { previous, next, showSlug } = Astro.props;

function hrefFor(episode) {
  return `/shows/${showSlug}/${episode.path}/`;
}
---

<nav class="episode-nav" aria-label="Episode navigation">
  <div>
    {
      previous && (
        <a href={hrefFor(previous)}>
          Previous: {previous.code} {previous.title}
        </a>
      )
    }
  </div>
  <div>
    {
      next && (
        <a href={hrefFor(next)}>
          Next: {next.code} {next.title}
        </a>
      )
    }
  </div>
</nav>
