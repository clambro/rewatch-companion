---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroImage from "../components/HeroImage.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const shows = await getCollection("shows");

type ShowEntry = CollectionEntry<"shows">;

function countsFor(show: ShowEntry) {
  return {
    characters: show.data.characters?.length ?? 0,
    episodes: show.data.seasons.reduce(
      (total: number, season) => total + season.episodes.length,
      0,
    ),
    themes: show.data.themes?.length ?? 0,
  };
}
---

<BaseLayout>
  <section class="show-masthead home-masthead">
    <p class="eyebrow">Rewatch Companion</p>
    <h1>Essays for viewers who already know the ending.</h1>
  </section>

  <section class="show-section home-guides">
    <div class="show-card-grid">
      {
        shows.map((show) => {
          const counts = countsFor(show);
          return (
            <a class="show-card" href={`/shows/${show.data.slug}`}>
              {show.data.hero_image ? (
                <div class="show-card-image-frame">
                  <HeroImage
                    class="show-card-image"
                    image={show.data.hero_image}
                    variant="card"
                    priority
                  />
                </div>
              ) : (
                <div class="show-card-image show-card-image-placeholder">
                  {show.data.title}
                </div>
              )}
              <h3>{show.data.title}</h3>
              <span>
                {counts.themes} themes · {counts.characters} characters ·{" "}
                {counts.episodes} episodes
              </span>
            </a>
          );
        })
      }

      <div class="show-card show-card-muted">
        <p>Coming Soon</p>
        <h3>More shows</h3>
        <span>More full-series companions are on the way.</span>
      </div>
    </div>
  </section>
</BaseLayout>
