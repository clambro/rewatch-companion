---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import SpoilerNotice from "../../../../components/SpoilerNotice.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const shows = await getCollection("shows");
  const metadataEntries = await getCollection("articleMetadata");
  const articles = await getCollection("articleArticles");

  return articles
    .filter((article) => article.id.endsWith("/about"))
    .map((article) => {
      const [showSlug] = article.id.split("/");
      const show = shows.find((entry) => entry.id === showSlug);
      const metadata = metadataEntries.find((entry) => entry.id === article.id);

      if (!show || !metadata) {
        throw new Error(`Missing show or about metadata for ${article.id}`);
      }

      return {
        params: { show: showSlug },
        props: { article, metadata, show },
      };
    });
}

const { article, metadata, show } = Astro.props;
const { Content } = await render(article);
const title = metadata.data.seo.title;
const description = metadata.data.seo.description;
---

<BaseLayout title={title} description={description}>
  <article class="episode">
    <p class="eyebrow">{show.data.title} Series Essay</p>
    <h1>{article.data.title ?? metadata.data.title}</h1>
    {article.data.dek && <p class="dek">{article.data.dek}</p>}

    <SpoilerNotice />

    <div class="article-body">
      <Content />
    </div>
  </article>
</BaseLayout>
