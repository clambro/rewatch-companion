---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const shows = await getCollection("shows");
  const articleMetadata = await getCollection("articleMetadata");
  const episodeMetadata = await getCollection("episodeMetadata");

  return shows.map((show) => {
    const metadataById = new Map(
      [...articleMetadata, ...episodeMetadata]
        .filter((entry) => entry.id.startsWith(`${show.data.slug}/`))
        .map((entry) => [entry.id, entry]),
    );

    return {
      params: { show: show.data.slug },
      props: { metadataById, show },
    };
  });
}

const { metadataById, show } = Astro.props;
const showHeroImage = show.data.hero_image;

function cardFor(entry) {
  const metadata = metadataById.get(`${show.data.slug}/${entry.path}`);
  return {
    ...entry,
    description: metadata?.data.seo.description,
    heroImage: metadata?.data.hero_image,
  };
}

function episodeCardFor(episode) {
  const metadata = metadataById.get(`${show.data.slug}/${episode.path}`);
  return {
    ...episode,
    description: metadata?.data.seo.description,
    heroImage: metadata?.data.hero_image,
    label: episode.code,
  };
}

const themeCards = (show.data.themes ?? []).map(cardFor);
const characterCards = (show.data.characters ?? []).map(cardFor);
const seasonCards = show.data.seasons.map((season) => ({
  ...season,
  episodes: season.episodes.map(episodeCardFor),
}));
---

<BaseLayout
  title={`${show.data.title} | Rewatch Companion`}
  description={`Full-series essays for ${show.data.title}.`}
>
  <section class="show-masthead">
    <div class="show-masthead-copy">
      <p class="eyebrow">Show Guide</p>
      <h1>{show.data.title}</h1>
      <p class="show-dek">
        Full-series essays written for viewers who already know the ending.
      </p>
    </div>

    <figure
      class:list={["show-hero", { "show-hero-placeholder": !showHeroImage }]}
    >
      {
        showHeroImage ? (
          <img src={showHeroImage.src} alt={showHeroImage.alt} />
        ) : (
          <div>{show.data.title}</div>
        )
      }
    </figure>
  </section>

  <section class="show-catalog" data-show-catalog>
    <nav
      class="catalog-tabs"
      aria-label={`${show.data.title} catalog sections`}
    >
      <button type="button" data-catalog-tab="episodes" aria-selected="true">
        Episodes
      </button>
      <button type="button" data-catalog-tab="themes" aria-selected="false">
        Themes
      </button>
      <button type="button" data-catalog-tab="characters" aria-selected="false">
        Characters
      </button>
    </nav>

    <section class="catalog-panel" data-catalog-panel="episodes">
      <div class="catalog-panel-header catalog-panel-header-tabs">
        <nav class="season-tabs" aria-label={`${show.data.title} seasons`}>
          {
            seasonCards.map((season, index) => (
              <button
                type="button"
                data-season-tab={`season-${season.season}`}
                aria-selected={index === 0 ? "true" : "false"}
              >
                Season {season.season}
              </button>
            ))
          }
        </nav>
      </div>

      {
        seasonCards.map((season, index) => (
          <section
            class="season-panel"
            data-season-panel={`season-${season.season}`}
            hidden={index !== 0}
          >
            <div class="essay-card-grid episode-card-grid">
              {season.episodes.map((card) => (
                <a
                  class="essay-card episode-card"
                  href={`/shows/${show.data.slug}/${card.path}/`}
                >
                  {card.heroImage ? (
                    <img
                      class="essay-card-image"
                      src={card.heroImage.src}
                      alt={card.heroImage.alt}
                      loading="lazy"
                    />
                  ) : (
                    <div class="essay-card-image essay-card-image-placeholder">
                      {card.label}
                    </div>
                  )}
                  <div class="essay-card-content">
                    <p>{card.label}</p>
                    <h3>{card.title}</h3>
                    {card.description && <span>{card.description}</span>}
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </section>

    <section class="catalog-panel" data-catalog-panel="themes" hidden>
      <div class="catalog-panel-header">
        <h2>Themes</h2>
      </div>
      <div class="essay-card-grid">
        {
          themeCards.map((card) => (
            <a
              class="essay-card"
              href={`/shows/${show.data.slug}/${card.path}/`}
            >
              {card.heroImage ? (
                <img
                  class="essay-card-image"
                  src={card.heroImage.src}
                  alt={card.heroImage.alt}
                  loading="lazy"
                />
              ) : (
                <div class="essay-card-image essay-card-image-placeholder">
                  {card.label ?? ""}
                </div>
              )}
              <div class="essay-card-content">
                {card.label && <p>{card.label}</p>}
                <h3>{card.title}</h3>
                {card.description && <span>{card.description}</span>}
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section class="catalog-panel" data-catalog-panel="characters" hidden>
      <div class="catalog-panel-header">
        <h2>Characters</h2>
      </div>
      <div class="essay-card-grid">
        {
          characterCards.map((card) => (
            <a
              class="essay-card"
              href={`/shows/${show.data.slug}/${card.path}/`}
            >
              {card.heroImage ? (
                <img
                  class="essay-card-image"
                  src={card.heroImage.src}
                  alt={card.heroImage.alt}
                  loading="lazy"
                />
              ) : (
                <div class="essay-card-image essay-card-image-placeholder">
                  {card.label ?? ""}
                </div>
              )}
              <div class="essay-card-content">
                {card.label && <p>{card.label}</p>}
                <h3>{card.title}</h3>
                {card.description && <span>{card.description}</span>}
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </section>

  <script>
    document.querySelectorAll("[data-show-catalog]").forEach((catalog) => {
      const catalogTabs = catalog.querySelectorAll("[data-catalog-tab]");
      const catalogPanels = catalog.querySelectorAll("[data-catalog-panel]");
      const seasonTabs = catalog.querySelectorAll("[data-season-tab]");
      const seasonPanels = catalog.querySelectorAll("[data-season-panel]");

      catalogTabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const target = tab.getAttribute("data-catalog-tab");
          catalogTabs.forEach((item) => {
            item.setAttribute("aria-selected", String(item === tab));
          });
          catalogPanels.forEach((panel) => {
            panel.toggleAttribute(
              "hidden",
              panel.getAttribute("data-catalog-panel") !== target,
            );
          });
        });
      });

      seasonTabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const target = tab.getAttribute("data-season-tab");
          seasonTabs.forEach((item) => {
            item.setAttribute("aria-selected", String(item === tab));
          });
          seasonPanels.forEach((panel) => {
            panel.toggleAttribute(
              "hidden",
              panel.getAttribute("data-season-panel") !== target,
            );
          });
        });
      });
    });
  </script>
</BaseLayout>
