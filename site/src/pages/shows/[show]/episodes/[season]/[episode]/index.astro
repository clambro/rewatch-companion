---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import EssayNav from "../../../../../../components/EssayNav.astro";
import EssaySidebar from "../../../../../../components/EssaySidebar.astro";
import SpoilerNotice from "../../../../../../components/SpoilerNotice.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  function flattenEpisodes(show) {
    return show.data.seasons.flatMap((season) => season.episodes);
  }

  const shows = await getCollection("shows");
  const metadataEntries = await getCollection("episodeMetadata");
  const articles = await getCollection("episodeArticles");

  return articles.map((article) => {
    const [showSlug, , season, episode] = article.id.split("/");
    const show = shows.find((entry) => entry.id === showSlug);
    const metadata = metadataEntries.find((entry) => entry.id === article.id);

    if (!show || !metadata) {
      throw new Error(`Missing show or episode metadata for ${article.id}`);
    }

    const episodes = flattenEpisodes(show);
    const currentIndex = episodes.findIndex(
      (item) => item.path === `episodes/${season}/${episode}`,
    );

    return {
      params: { show: showSlug, season, episode },
      props: {
        article,
        currentPath: `episodes/${season}/${episode}`,
        metadata,
        show,
        previous: currentIndex > 0 ? episodes[currentIndex - 1] : null,
        next:
          currentIndex >= 0 && currentIndex < episodes.length - 1
            ? episodes[currentIndex + 1]
            : null,
      },
    };
  });
}

const { article, currentPath, metadata, show, previous, next } = Astro.props;
const { Content } = await render(article);
const title = metadata.data.seo.title;
const description = metadata.data.seo.description;
const heroImage = metadata.data.hero_image;
const placeholderLabel = `${show.data.title} / ${metadata.data.code}`;
---

<BaseLayout title={title} description={description} type="article">
  <article class="article-shell">
    <EssaySidebar
      show={show}
      currentPath={currentPath}
      previous={previous}
      next={next}
    />

    <div class="article-main">
      <header class="article-header">
        <div class="article-kicker">
          <span>{show.data.title}</span>
          <span>Episode Analysis</span>
          <span>{metadata.data.code}</span>
        </div>
        <h1>{metadata.data.title}</h1>
        <p class="dek">{description}</p>
      </header>

      <figure
        class:list={[
          "article-hero",
          { "article-hero-placeholder": !heroImage },
        ]}
      >
        {
          heroImage ? (
            <>
              <img src={heroImage.src} alt={heroImage.alt} />
            </>
          ) : (
            <div>{placeholderLabel}</div>
          )
        }
      </figure>

      <SpoilerNotice />

      <div class="article-body">
        <Content />
      </div>

      <EssayNav
        previous={previous}
        next={next}
        showSlug={show.data.slug}
        showTitle={show.data.title}
        variant="footer"
      />
    </div>
  </article>
</BaseLayout>
