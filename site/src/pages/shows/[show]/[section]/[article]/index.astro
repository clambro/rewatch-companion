---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import EssayNav from "../../../../../components/EssayNav.astro";
import EssaySidebar from "../../../../../components/EssaySidebar.astro";
import HeroImage from "../../../../../components/HeroImage.astro";
import SpoilerNotice from "../../../../../components/SpoilerNotice.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

type ShowEntry = CollectionEntry<"shows">;
type ArticleEntry = CollectionEntry<"articleArticles">;
type ArticleMetadata = CollectionEntry<"articleMetadata">;
type ArticleSection = "themes" | "characters";
type ListedArticle = NonNullable<ShowEntry["data"]["themes"]>[number];

interface Props {
  article: ArticleEntry;
  currentPath: string;
  metadata: ArticleMetadata;
  next: ListedArticle | null;
  previous: ListedArticle | null;
  section: ArticleSection;
  show: ShowEntry;
}

export async function getStaticPaths() {
  function sectionEntries(show: ShowEntry, section: ArticleSection) {
    if (section === "themes") {
      return show.data.themes ?? [];
    }
    if (section === "characters") {
      return show.data.characters ?? [];
    }
    return [];
  }

  const allowedSections = new Set(["themes", "characters"]);
  const shows = await getCollection("shows");
  const metadataEntries = await getCollection("articleMetadata");
  const articles = await getCollection("articleArticles");

  return articles.map((article) => {
    const [showSlug, section, articleSlug] = article.id.split("/");
    const show = shows.find((entry) => entry.id === showSlug);
    const metadata = metadataEntries.find((entry) => entry.id === article.id);

    if (!show || !metadata) {
      throw new Error(`Missing show or article metadata for ${article.id}`);
    }

    if (
      !section ||
      !articleSlug ||
      !allowedSections.has(section as ArticleSection)
    ) {
      throw new Error(`Unsupported article section for ${article.id}`);
    }

    const typedSection = section as ArticleSection;
    const entries = sectionEntries(show, typedSection);
    const currentPath = `${section}/${articleSlug}`;
    const currentIndex = entries.findIndex(
      (entry: ListedArticle) => entry.path === currentPath,
    );

    return {
      params: { show: showSlug, section, article: articleSlug },
      props: {
        article,
        currentPath,
        metadata,
        next:
          currentIndex >= 0 && currentIndex < entries.length - 1
            ? entries[currentIndex + 1]
            : null,
        previous: currentIndex > 0 ? entries[currentIndex - 1] : null,
        section,
        show,
      },
    };
  });
}

const { article, currentPath, metadata, next, previous, show, section } =
  Astro.props as Props;
const { Content } = await render(article);
const title = metadata.data.seo.title;
const description = metadata.data.seo.description;
const heroImage = metadata.data.hero_image;
const sectionLabels: Record<ArticleSection, string> = {
  themes: "Themes",
  characters: "Characters",
};
const label = sectionLabels[section];
const placeholderLabel = `${show.data.title} / ${label}`;
---

<BaseLayout title={title} description={description} type="article">
  <article class="article-shell">
    <EssaySidebar
      show={show}
      currentPath={currentPath}
      previous={previous}
      next={next}
    />

    <div class="article-main">
      <header class="article-header">
        <div class="article-kicker">
          <span>{show.data.title}</span>
          <span>{label}</span>
        </div>
        <h1>{metadata.data.title}</h1>
        <p class="dek">{description}</p>
      </header>

      <figure
        class:list={[
          "article-hero",
          { "article-hero-placeholder": !heroImage },
        ]}
      >
        {
          heroImage ? (
            <>
              <HeroImage image={heroImage} variant="article" priority />
            </>
          ) : (
            <div>{placeholderLabel}</div>
          )
        }
      </figure>

      <SpoilerNotice />

      <div class="article-body">
        <Content />
      </div>

      <EssayNav
        previous={previous}
        next={next}
        showSlug={show.data.slug}
        showTitle={show.data.title}
        variant="footer"
      />
    </div>
  </article>
</BaseLayout>
