---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import SpoilerNotice from "../../../../../components/SpoilerNotice.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const allowedSections = new Set(["about", "themes", "characters"]);
  const shows = await getCollection("shows");
  const metadataEntries = await getCollection("articleMetadata");
  const articles = await getCollection("articleArticles");

  return articles.map((article) => {
    const [showSlug, section, articleSlug] = article.id.split("/");
    const show = shows.find((entry) => entry.id === showSlug);
    const metadata = metadataEntries.find((entry) => entry.id === article.id);

    if (!show || !metadata) {
      throw new Error(`Missing show or article metadata for ${article.id}`);
    }

    if (!section || !articleSlug || !allowedSections.has(section)) {
      throw new Error(`Unsupported article section for ${article.id}`);
    }

    return {
      params: { show: showSlug, section, article: articleSlug },
      props: { article, metadata, show, section },
    };
  });
}

const { article, metadata, show, section } = Astro.props;
const { Content } = await render(article);
const title = metadata.data.seo.title;
const description = metadata.data.seo.description;
const label =
  metadata.data.type === "about"
    ? "Series Essay"
    : metadata.data.type === "theme"
      ? "Theme Essay"
      : "Character Essay";
---

<BaseLayout title={title} description={description}>
  <article class="episode">
    <p class="eyebrow">{show.data.title} {label}</p>
    <h1>{article.data.title ?? metadata.data.title}</h1>
    {article.data.dek && <p class="dek">{article.data.dek}</p>}

    <SpoilerNotice />

    <div class="article-body">
      <Content />
    </div>
  </article>
</BaseLayout>
